{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "../../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "experimentalDecorators": true
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts", "../../../src/core/**/*.ts", "../../../schema/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
