{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true
  },
  "include": [
    "shared/**/*.ts",
    "static/**/*.ts",
    "snapshot/**/*.ts",
    "incremental/**/*.ts",
    "manual/**/*.ts",
    "../../src/core/**/*.ts"
  ]
}
